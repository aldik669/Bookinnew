# Поддомен amoCRM (без .amocrm.ru), например для https://mycompany.amocrm.ru это "mycompany"
AMO_SUBDOMAIN=

# Долгосрочный токен интеграции amoCRM (Bearer)
AMO_TOKEN=

# ID воронки, в которой ищем сделки
AMO_PIPELINE_ID=

# ID этапа "Назначено пробное" внутри этой воронки
AMO_STATUS_ID=

# ID кастомного поля сделки "Дата и Время МК (свое)" (старая система расписаний)
AMO_FIELD_MK_ID=

# Новая система расписаний по возрастным группам (опционально — если не заполнить,
# работает только старое поле выше)
AMO_FIELD_DATE_MK_ID=
AMO_FIELD_TIME_WEEKDAY_ID=
AMO_FIELD_TIME_WEEKEND_ID=

# Лимит записей на один слот (дата+время)
SLOT_LIMIT=16

# Порт, на котором запускается сервер
PORT=3000
